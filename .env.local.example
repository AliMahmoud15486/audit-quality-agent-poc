# Copy to .env.local and fill in your key.
# The POC runs on Anthropic's Claude — the same foundation-model layer Cortea
# describes itself as sitting on top of ("a layer above Anthropic and OpenAI").
ANTHROPIC_API_KEY=sk-ant-...

# Optional override (defaults to claude-opus-4-8)
# CORTEA_POC_MODEL=claude-opus-4-8

# Optional. Enables Braintrust observability:
#   - required to run `npm run eval:braintrust`
#   - when set in the deployed env (e.g. Vercel), live /api/check requests are
#     traced too. Leave unset and the app + API run untraced, exactly as before.
# BRAINTRUST_API_KEY=sk-...
