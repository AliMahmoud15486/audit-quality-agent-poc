# Copy to .env.local and fill in your key.
# The POC runs on Anthropic's Claude — the same foundation-model layer Cortea
# describes itself as sitting on top of ("a layer above Anthropic and OpenAI").
ANTHROPIC_API_KEY=sk-ant-...

# Optional override (defaults to claude-opus-4-8)
# CORTEA_POC_MODEL=claude-opus-4-8
